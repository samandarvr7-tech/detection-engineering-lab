# Local .terraform directories
**/.terraform/*

# .tfstate files (They contain sensitive info about your infrastructure)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude sensitive variables
*.tfvars
*.tfvars.json

# Ignore override files as they are usually local customizations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

.DS_Store